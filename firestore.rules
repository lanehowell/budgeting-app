rules_version = '2';

// All user data lives under /users/{userId}/...
// Each known collection is allowlisted explicitly. Anything not listed —
// notably __private/{...} where the SimpleFIN access URL lives — is denied.
// Cloud Functions use the Admin SDK, which bypasses these rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      match /categories/{document=**} {
        allow read, write: if isOwner();
      }

      match /bills/{document=**} {
        allow read, write: if isOwner();
      }

      match /billPayments/{document=**} {
        allow read, write: if isOwner();
      }

      match /transactions/{document=**} {
        allow read, write: if isOwner();
      }

      match /merchantRules/{document=**} {
        allow read, write: if isOwner();
      }

      match /meta/{document=**} {
        allow read, write: if isOwner();
      }

      // Read-only on the client: clients see their accounts but only Cloud
      // Functions create / update them as part of SimpleFIN sync.
      match /accounts/{document=**} {
        allow read: if isOwner();
        allow write: if false;
      }

      // __private holds server-only data (SimpleFIN access URL, SimpleFIN
      // sync cursors). Clients can never read or write here.
      match /__private/{document=**} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
